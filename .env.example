# B20 Watcher environment configuration

# Data mode. Default: true (mock data, no external calls, no CDP token needed).
# Set to "false" to use the live Coinbase CDP SQL API data source.
MOCK_MODE=true

# Network to scan in live mode. Allowed: base | base_sepolia
# (the hyphenated form "base-sepolia" is normalized to "base_sepolia").
B20_NETWORK=base

# CDP SQL API bearer token. REQUIRED when MOCK_MODE=false.
# Server-side only — never exposed to the browser. Never commit a real token.
CDP_BEARER_TOKEN=

# maxAgeMs passed to the CDP SQL cache. Default: 3000.
CDP_SQL_CACHE_MAX_AGE_MS=3000

# B20 factory address used for token discovery in live mode.
B20_FACTORY_ADDRESS=0xB20f000000000000000000000000000000000000
