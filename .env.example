# B20 Watcher environment configuration

# Run in mock mode (no external data source needed). Default: true.
# Set to "false" to wire up a real data source (not required for this MVP).
MOCK_MODE=true

# Network to scan when running with real data (base | base-sepolia).
B20_NETWORK=base

# CDP SQL API bearer token. Only needed when MOCK_MODE=false.
# Never commit a real token. This MVP does NOT require CDP integration.
CDP_BEARER_TOKEN=

# B20 factory address used for token discovery (real-data mode only).
B20_FACTORY_ADDRESS=0xB20f000000000000000000000000000000000000
