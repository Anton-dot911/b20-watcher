# B20 Watcher environment configuration

# Data mode. Default: true (mock data, no external calls, no CDP token needed).
# Set to "false" to use a live data source selected by DATA_SOURCE below.
MOCK_MODE=true

# Live data source, used only when MOCK_MODE=false. Allowed: mock | cdp | supabase
#   mock     -> bundled mock data (same as MOCK_MODE=true)
#   cdp      -> query the Coinbase CDP SQL API directly on each request
#   supabase -> read cached snapshots/reports from Supabase (populated via the
#               refresh endpoints/scripts). Invalid values fall back to cdp.
DATA_SOURCE=mock

# Network to scan in live mode. Allowed: base | base_sepolia
# (the hyphenated form "base-sepolia" is normalized to "base_sepolia").
B20_NETWORK=base

# B20 factory address used for token discovery in live mode.
B20_FACTORY_ADDRESS=0xB20f000000000000000000000000000000000000

# CDP SQL API bearer token. REQUIRED when DATA_SOURCE=cdp, and when running the
# refresh endpoints/scripts (which always pull fresh data from CDP).
# Server-side only — never exposed to the browser. Never commit a real token.
CDP_BEARER_TOKEN=

# maxAgeMs passed to the CDP SQL cache. Default: 3000.
CDP_SQL_CACHE_MAX_AGE_MS=3000

# Supabase project URL. Carries the NEXT_PUBLIC_ prefix so it MAY be exposed to
# the client, but all reads/writes in this app go through the server-only
# service-role client. REQUIRED when DATA_SOURCE=supabase and for refresh.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase service-role key. SERVER-SIDE ONLY — a full-access key. Never expose
# it to client bundles; it is read only inside lib/supabase-server.ts
# (server-only). REQUIRED when DATA_SOURCE=supabase and for refresh.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret required by the refresh endpoints via the x-refresh-secret
# header. REQUIRED to run any refresh endpoint; requests without it get 401.
REFRESH_SECRET=
